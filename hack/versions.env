# Shared version pins for cluster-wide add-ons installed by both `make
# install-e2e-deps` and hack/generate-screenshots.sh, so the two never drift
# out of sync. Valid as both a Makefile `include` and a bash `source` file --
# keep it to plain VAR=value lines only.
GATEWAY_API_VERSION=v1.6.0
CERT_MANAGER_VERSION=v1.21.0
CROSSPLANE_VERSION=2.3.3
EXTERNAL_SNAPSHOTTER_VERSION=v8.2.0
KARPENTER_VERSION=v1.14.0
