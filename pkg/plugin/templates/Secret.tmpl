{{- define "Secret" }}
    {{- /*gotype: github.com/bergerx/kubectl-status/pkg/plugin.RenderableObject*/ -}}
    {{- /* GVK: v1, Kind=Secret */ -}}
    {{- /* kstatus_summary omitted: Secret is always reported "Resource is always ready" by kstatus, same as CronJob. */ -}}
    {{- template "status_summary_line" . }}
    {{- template "finalizer_details_on_termination" . }}
    {{- template "observed_generation_summary" . }}
    {{- template "application_details" . }}
    {{- /* Opaque is the Kubernetes default -- suppressed per the "omit defaults" convention.
           kubernetes.io/tls and the dockerconfigjson/dockercfg pair already get their own
           dedicated sections below (Certificate for.../Registries:), which imply the type, so
           spelling it out here too would be redundant. Every other declared type (basic-auth,
           ssh-auth, service-account-token, bootstrap.kubernetes.io/token, custom types, ...) has
           no other indicator anywhere in the output, so show it. */ -}}
    {{- if and .Object.type (ne .Object.type "Opaque") (not (has .Object.type (list "kubernetes.io/tls" "kubernetes.io/dockerconfigjson" "kubernetes.io/dockercfg"))) }}
        {{- "Type" | bold | nindent 2 }}: {{ .Object.type | cyan }}
    {{- end }}
    {{- with index .Annotations "cert-manager.io/certificate-name" }}
        {{- $certName := . }}
        {{- $issuerKind := index $.Annotations "cert-manager.io/issuer-kind" }}
        {{- $issuerName := index $.Annotations "cert-manager.io/issuer-name" }}
        {{- $issuerGroup := index $.Annotations "cert-manager.io/issuer-group" }}
        {{- $issuerNamespace := "" }}
        {{- if ne $issuerKind "ClusterIssuer" }}{{ $issuerNamespace = $.Namespace }}{{ end }}
        {{- if $.Config.GetBool "deep" }}
            {{- /* Nested full renders don't fit in a "Certificate via Issuer" prose line, so
                   deep mode lists each reference on its own indented line instead. */ -}}
            {{- "Managed by" | bold | nindent 2 }}
            {{- $certObj := $.KubeGetFirst $.Namespace "Certificate" $certName }}
            {{- if $certObj.Object }}
                {{- $.IncludeRenderableObject $certObj | nindent 4 }}
            {{- else }}
                {{- template "resource_ref" (dict "kind" "Certificate" "name" $certName) | nindent 4 }}
            {{- end }}
            {{- with $issuerKind }}
                {{- $issuerObj := $.KubeGetFirst $issuerNamespace . $issuerName }}
                {{- if $issuerObj.Object }}
                    {{- $.IncludeRenderableObject $issuerObj | nindent 4 }}
                {{- else }}
                    {{- template "resource_ref" (dict "kind" . "name" $issuerName) | nindent 4 }}
                {{- end }}
            {{- end }}
        {{- else }}
            {{- "Managed by" | bold | nindent 2 }} {{ template "resource_ref" (dict "kind" "Certificate" "name" $certName) }}
            {{- with $issuerKind }}
                {{- " via " }}{{ template "resource_ref" (dict "kind" . "name" $issuerName) }}
                {{- with $issuerGroup }} ({{ . | cyan }}){{ end }}
            {{- end }}
        {{- end }}
    {{- end }}
    {{- if eq .Object.type "kubernetes.io/tls" }}
        {{- $cert := parseTLSSecretCertificate . "" }}
        {{- if or (not $cert.Exists) $cert.WrongType $cert.MissingKeys $cert.ParseError }}
            {{- if not $cert.Exists }}
                {{- "Secret has no data" | red | bold | nindent 2 }}
            {{- end }}
            {{- if $cert.WrongType }}
                {{- "Unexpected type" | red | bold | nindent 2 }}: expected {{ "kubernetes.io/tls" | cyan }}, got {{ $cert.ActualType | red }}
            {{- end }}
            {{- with $cert.MissingKeys }}
                {{- "Missing keys" | red | bold | nindent 2 }}: {{ join ", " . | red }}
            {{- end }}
            {{- with $cert.ParseError }}
                {{- "Certificate parse error" | red | bold | nindent 2 }}: {{ . | red }}
            {{- end }}
        {{- else }}
            {{- "Certificate for" | nindent 2 }} {{ $cert.Subject | cyan }}
            {{- with $cert.Issuer }} · issued by {{ . | cyan }}{{ end }}
            {{- with $cert.AltDNSNames }}
                {{- "Also valid for" | bold | nindent 4 }}: {{ join ", " . | cyan }}
            {{- end }}
            {{- with $cert.IPAddresses }}
                {{- "IPs" | bold | nindent 4 }}: {{ join ", " . | cyan }}
            {{- end }}
            {{- if $cert.SelfSigned }}
                {{- "Self-signed" | yellow | bold | nindent 4 }}: issuer and subject match, not issued by a separate CA
            {{- end }}
            {{- template "certificate_validity_line" (dict "cert" $cert) }}
            {{- "Key" | bold | nindent 4 }}: {{ $cert.KeyAlgorithm | cyan }}
            {{- with $cert.SerialNumber }} · serial {{ . | cyan }}{{ end }}
        {{- end }}
    {{- end }}
    {{- if has .Object.type (list "kubernetes.io/dockerconfigjson" "kubernetes.io/dockercfg") }}
        {{- $dc := parseDockerConfigSecret . }}
        {{- with $dc.MissingKey }}
            {{- "Secret has no data" | red | bold | nindent 2 }}: missing {{ . | red }}
        {{- end }}
        {{- with $dc.ParseError }}
            {{- "Docker config parse error" | red | bold | nindent 2 }}: {{ . | red }}
        {{- end }}
        {{- if and (not $dc.MissingKey) (not $dc.ParseError) }}
            {{- if $dc.Registries }}
                {{- "Registries" | bold | nindent 2 }}: {{ join ", " $dc.Registries | cyan }}
            {{- else }}
                {{- "No registries configured" | red | bold | nindent 2 }}
            {{- end }}
        {{- end }}
    {{- end }}
    {{- if eq .Object.type "kubernetes.io/basic-auth" }}
        {{- $ba := parseBasicAuthSecret . }}
        {{- if not $ba.HasUsername }}
            {{- "Username" | red | bold | nindent 2 }}: {{ "missing" | red }}
        {{- else if $ba.UsernameEmpty }}
            {{- "Username" | red | bold | nindent 2 }}: {{ "empty" | red }}
        {{- end }}
        {{- if not $ba.HasPassword }}
            {{- "Password" | red | bold | nindent 2 }}: {{ "missing" | red }}
        {{- else if $ba.PasswordEmpty }}
            {{- "Password" | red | bold | nindent 2 }}: {{ "empty" | red }}
        {{- end }}
    {{- end }}
    {{- if eq .Object.type "kubernetes.io/ssh-auth" }}
        {{- $ssh := parseSSHAuthSecret . }}
        {{- if not $ssh.Exists }}
            {{- "Secret has no data" | red | bold | nindent 2 }}: missing {{ "ssh-privatekey" | red }}
        {{- else if $ssh.ParseError }}
            {{- "Private key parse error" | red | bold | nindent 2 }}: {{ $ssh.ParseError | red }}
        {{- else }}
            {{- "Private key" | bold | nindent 2 }} ({{ $ssh.KeyType | cyan }})
            {{- "Fingerprint" | bold | nindent 4 }}: {{ $ssh.Fingerprint | cyan }}
        {{- end }}
    {{- end }}
    {{- if eq .Object.type "kubernetes.io/service-account-token" }}
        {{- $sat := parseServiceAccountTokenSecret . }}
        {{- if not $sat.HasServiceAccountName }}
            {{- "Missing" | red | bold | nindent 2 }} {{ "kubernetes.io/service-account.name" | cyan }} annotation
        {{- else }}
            {{- $saName := $sat.ServiceAccountName }}
            {{- "Service account" | bold | nindent 2 }} {{ template "resource_ref" (dict "kind" "ServiceAccount" "name" $saName "namespace" $.Namespace "callerNamespace" $.Namespace) }}
            {{- if $.Config.GetBool "deep" }}
                {{- $saObj := $.KubeGetFirst $.Namespace "ServiceAccount" $saName }}
                {{- if $saObj.Object }}
                    {{- $.IncludeRenderableObject $saObj | nindent 4 }}
                {{- end }}
            {{- end }}
            {{- if not $sat.HasToken }}
                {{- "Waiting for controller to populate token" | yellow | bold | nindent 2 }}
            {{- end }}
        {{- end }}
    {{- end }}
    {{- if eq .Object.type "bootstrap.kubernetes.io/token" }}
        {{- $bt := parseBootstrapTokenSecret . }}
        {{- if not $bt.NamespaceOK }}
            {{- "Wrong namespace" | red | bold | nindent 2 }}: bootstrap tokens are only honoured in {{ "kube-system" | cyan }}, got {{ $bt.ActualNamespace | red }}
        {{- end }}
        {{- if not $bt.NameOK }}
            {{- "Unexpected name" | red | bold | nindent 2 }}: expected {{ "bootstrap-token-<token-id>" | cyan }}
        {{- end }}
        {{- with $bt.MissingKeys }}
            {{- "Missing keys" | red | bold | nindent 2 }}: {{ join ", " . | red }}
        {{- end }}
        {{- if and $bt.TokenID (not $bt.TokenIDValid) }}
            {{- "Invalid token-id" | red | bold | nindent 2 }}: must be 6 lowercase alphanumeric characters
        {{- end }}
        {{- if and $bt.TokenIDValid $bt.NameOK (not $bt.TokenIDMatchesName) }}
            {{- "token-id doesn't match Secret name" | red | bold | nindent 2 }}
        {{- end }}
        {{- if and $bt.TokenSecretPresent (not $bt.TokenSecretValid) }}
            {{- "Invalid token-secret" | red | bold | nindent 2 }}: must be 16 lowercase alphanumeric characters
        {{- end }}
        {{- if $bt.HasExpiration }}
            {{- if $bt.Expired }}
                {{- "Expired" | red | bold | nindent 2 }} {{ $bt.Expiration.Format "2006-01-02" | red }} ({{ $bt.Expiration.UTC.Format "2006-01-02T15:04:05Z" | colorAgo }}{{ agoSuffix }})
            {{- else }}
                {{- "Expires" | bold | nindent 2 }}: {{ $bt.Expiration.Format "2006-01-02" | cyan }}{{ untilClause $bt.Expiration }}
            {{- end }}
        {{- else }}
            {{- "No expiration set" | yellow | bold | nindent 2 }}
        {{- end }}
        {{- "Usage" | bold | nindent 2 }}: authentication {{ if $bt.UsageAuthentication }}{{ "enabled" | green }}{{ else }}{{ "disabled" | red }}{{ end }} · signing {{ if $bt.UsageSigning }}{{ "enabled" | green }}{{ else }}{{ "disabled" | red }}{{ end }}
    {{- end }}
    {{- if or (eq .Object.type "Opaque") (not .Object.type) }}
        {{- with secretDataKeys . }}
            {{- "Keys" | bold | nindent 2 }}: {{ join ", " . | cyan }}
        {{- end }}
    {{- end }}
    {{- range $c := certificatesInSecret . }}
        {{- if and (eq $.Object.type "kubernetes.io/tls") (eq $c.Name "tls.crt") }}
            {{- /* already rendered above by the kubernetes.io/tls block */ -}}
        {{- else }}
            {{- with $c.ParseError }}
                {{- "Certificate" | red | bold | nindent 2 }} ({{ $c.Name | cyan }}): {{ . | red }}
            {{- else }}
                {{- "Certificate" | bold | nindent 2 }} ({{ $c.Name | cyan }}) for {{ $c.Subject | cyan }}
                {{- with $c.Issuer }} · issued by {{ . | cyan }}{{ end }}
                {{- with $c.AltDNSNames }}
                    {{- "Also valid for" | bold | nindent 4 }}: {{ join ", " . | cyan }}
                {{- end }}
                {{- with $c.IPAddresses }}
                    {{- "IPs" | bold | nindent 4 }}: {{ join ", " . | cyan }}
                {{- end }}
                {{- if $c.SelfSigned }}
                    {{- "Self-signed" | yellow | bold | nindent 4 }}: issuer and subject match, not issued by a separate CA
                {{- end }}
                {{- template "certificate_validity_line" (dict "cert" $c) }}
                {{- "Key" | bold | nindent 4 }}: {{ $c.KeyAlgorithm | cyan }}
                {{- with $c.SerialNumber }} · serial {{ . | cyan }}{{ end }}
            {{- end }}
        {{- end }}
    {{- end }}
    {{- template "conditions_summary" . }}
    {{- template "recent_updates" . }}
    {{- template "events" . }}
    {{- template "owners" . }}
{{- end }}
