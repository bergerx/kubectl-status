{{- define "SecretStore" }}
    {{- /*gotype: github.com/bergerx/kubectl-status/pkg/plugin.RenderableObject*/ -}}
    {{- /* GVK: external-secrets.io/v1, Kind=SecretStore */ -}}
    {{- template "status_summary_line" . }}
    {{- template "kstatus_summary" . }}
    {{- template "finalizer_details_on_termination" . }}
    {{- template "observed_generation_summary" . }}
    {{- template "application_details" . }}
    {{- with .Spec.provider }}
        {{- if .webhook }}
            {{- "Provider" | bold | nindent 2 }}: {{ "Webhook" | cyan }} {{ .webhook.method | default "POST" | cyan }} {{ .webhook.url | cyan }}
        {{- else if .vault }}
            {{- "Provider" | bold | nindent 2 }}: {{ "Vault" | cyan }} at {{ .vault.server | cyan }}
            {{- with .vault.path }} · path {{ . | cyan }}{{ end }}
            {{- with .vault.namespace }}
                {{- "Namespace" | bold | nindent 4 }}: {{ . | cyan }}
            {{- end }}
            {{- with .vault.auth }}
                {{- if .appRole }}{{- "Auth" | bold | nindent 4 }}: {{ "AppRole" | cyan }}{{ end }}
                {{- if .kubernetes }}{{- "Auth" | bold | nindent 4 }}: {{ "Kubernetes" | cyan }} · role={{ .kubernetes.role | cyan }}{{ end }}
                {{- if .tokenSecretRef }}{{- "Auth" | bold | nindent 4 }}: {{ "Token" | cyan }}{{ end }}
                {{- if .jwt }}{{- "Auth" | bold | nindent 4 }}: {{ "JWT" | cyan }}{{ end }}
                {{- if .cert }}{{- "Auth" | bold | nindent 4 }}: {{ "Certificate" | cyan }}{{ end }}
            {{- end }}
        {{- else if .aws }}
            {{- "Provider" | bold | nindent 2 }}: {{ "AWS" | cyan }} {{ .aws.service | cyan }}
            {{- with .aws.region }} · {{ . | cyan }}{{ end }}
            {{- with .aws.role }}
                {{- "Role" | bold | nindent 4 }}: {{ . | cyan }}
            {{- end }}
        {{- else if .azurekv }}
            {{- "Provider" | bold | nindent 2 }}: {{ "Azure Key Vault" | cyan }}
            {{- with .azurekv.vaultUrl }} at {{ . | cyan }}{{ end }}
        {{- else if .gcpsm }}
            {{- "Provider" | bold | nindent 2 }}: {{ "GCP Secret Manager" | cyan }}
            {{- with .gcpsm.projectID }} · project {{ . | cyan }}{{ end }}
        {{- else if .doppler }}
            {{- "Provider" | bold | nindent 2 }}: {{ "Doppler" | cyan }}
            {{- with .doppler.project }} · project {{ . | cyan }}{{ end }}
            {{- with .doppler.config }}/{{ . | cyan }}{{ end }}
        {{- else if .onepassword }}
            {{- "Provider" | bold | nindent 2 }}: {{ "1Password" | cyan }} at {{ .onepassword.connectHost | cyan }}
            {{- with .onepassword.vaults }}
                {{- if eq (len .) 1 }} · vault {{ (index . 0).name | cyan }}
                {{- else }}
                    {{- range . }}
                        {{- .name | cyan | nindent 4 }}
                    {{- end }}
                {{- end }}
            {{- end }}
        {{- else if .ibm }}
            {{- "Provider" | bold | nindent 2 }}: {{ "IBM Secrets Manager" | cyan }}
            {{- with .ibm.serviceUrl }} at {{ . | cyan }}{{ end }}
        {{- else if .infisical }}
            {{- "Provider" | bold | nindent 2 }}: {{ "Infisical" | cyan }}
            {{- with .infisical.hostAPI }} at {{ . | cyan }}{{ end }}
            {{- with .infisical.secretsScope }}
                {{- with .projectSlug }} · project {{ . | cyan }}{{ end }}
                {{- with .envSlug }}/{{ . | cyan }}{{ end }}
                {{- with .secretsPath }}/{{ . | cyan }}{{ end }}
            {{- end }}
        {{- else if .kubernetes }}
            {{- "Provider" | bold | nindent 2 }}: {{ "Kubernetes" | cyan }}
        {{- else if .fake }}
            {{- "Provider" | bold | nindent 2 }}: {{ "Fake" | yellow | bold }}
        {{- else }}
            {{- "Provider" | bold | nindent 2 }}: {{ . | keys | first | cyan }}
        {{- end }}
    {{- end }}
    {{- with .Status.capabilities }}
        {{- if ne . "ReadWrite" }}
            {{- "Capabilities" | bold | nindent 2 }}: {{ . | cyan }}
        {{- end }}
    {{- end }}
    {{- with .Spec.controller }}
        {{- "Controller" | bold | nindent 2 }}: {{ . | cyan }}
    {{- end }}
    {{- if and .Spec.refreshInterval (ne (.Spec.refreshInterval | toString) "0") }}
        {{- "Store refresh" | bold | nindent 2 }}: every {{ .Spec.refreshInterval | toString | cyan }}s
    {{- end }}
    {{- with .Spec.retrySettings }}
        {{- "Retry" | bold | nindent 2 }}:
        {{- with .retryInterval }} every {{ . | cyan }}{{ end }}
        {{- with .maxRetries }}, max {{ . | toString | cyan }} attempts{{ end }}
    {{- end }}
    {{- template "conditions_summary" . }}
    {{- template "recent_updates" . }}
    {{- template "events" . }}
    {{- template "owners" . }}
{{- end }}
