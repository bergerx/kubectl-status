{{- define "ConfigMap" }}
    {{- /*gotype: github.com/bergerx/kubectl-status/pkg/plugin.RenderableObject*/ -}}
    {{- /* GVK: v1, Kind=ConfigMap */ -}}
    {{- /* kstatus_summary omitted: ConfigMap is always reported "Resource is always ready" by kstatus, same as Secret. */ -}}
    {{- template "status_summary_line" . }}
    {{- template "finalizer_details_on_termination" . }}
    {{- template "observed_generation_summary" . }}
    {{- template "application_details" . }}
    {{- with .Object.immutable }}
        {{- "Immutable" | bold | nindent 2 }}
    {{- end }}
    {{- range $c := certificatesInConfigMap . }}
        {{- with $c.ParseError }}
            {{- "Certificate" | red | bold | nindent 2 }} ({{ $c.Name | cyan }}): {{ . | red }}
        {{- else }}
            {{- "Certificate" | bold | nindent 2 }} ({{ $c.Name | cyan }}) for {{ $c.Subject | cyan }}
            {{- with $c.Issuer }} · issued by {{ . | cyan }}{{ end }}
            {{- with $c.AltDNSNames }}
                {{- "Also valid for" | bold | nindent 4 }}: {{ join ", " . | cyan }}
            {{- end }}
            {{- with $c.IPAddresses }}
                {{- "IPs" | bold | nindent 4 }}: {{ join ", " . | cyan }}
            {{- end }}
            {{- if $c.SelfSigned }}
                {{- "Self-signed" | yellow | bold | nindent 4 }}: issuer and subject match, not issued by a separate CA
            {{- end }}
            {{- "Valid" | bold | nindent 4 }} {{ $c.NotBefore.UTC.Format "2006-01-02T15:04:05Z" | colorAgo }}{{ agoSuffix }}, expires {{ $c.NotAfter.Format "2006-01-02" | cyan }}
            {{- "Key" | bold | nindent 4 }}: {{ $c.KeyAlgorithm | cyan }}
            {{- with $c.SerialNumber }} · serial {{ . | cyan }}{{ end }}
        {{- end }}
    {{- end }}
    {{- template "conditions_summary" . }}
    {{- template "recent_updates" . }}
    {{- template "events" . }}
    {{- template "owners" . }}
{{- end }}
