{{- define "PersistentVolumeClaim" }}
    {{- /*gotype: github.com/bergerx/kubectl-status/pkg/plugin.RenderableObject*/ -}}
    {{- template "status_summary_line" . }}
    {{- template "kstatus_summary" . }}
    {{- template "finalizer_details_on_termination" . }}
    {{- template "application_details" . }}
    {{- template "conditions_summary" . }}
    {{- "PVC" | nindent 2 }}
    {{- with .Spec.volumeName }} uses {{ "PersistentVolume" | bold }}/{{ . }}{{ end }}
    {{- with .Spec.volumeMode }}, with {{ . | bold }} mode{{ end }}
    {{- with .Status.capacity.storage }}, asks for {{ . | bold }}{{ end }}
    {{- with index .Annotations "volume.beta.kubernetes.io/storage-provisioner" }}, provisioned by {{ . | bold }}{{ end }}
    {{- with index .Annotations "volume.kubernetes.io/selected-node" }}, attached on {{ "Node" | bold }}/{{ . }}{{ end }}
    {{- if not .Spec.volumeName }}, {{ "Pending" | red | bold }}: no paired PV yet{{ end }}
    {{- /* Disk usage: find running pods that have this PVC mounted, collect usage stats from the first one */ -}}
    {{- $pvcName := $.Name }}
    {{- $volStats := dict }}
    {{- $usingPods := list }}
    {{- range $.KubeGet $.Namespace "pods" }}
        {{- $pod := . }}
        {{- range $pod.Spec.volumes | default list }}
            {{- if and (hasKey . "persistentVolumeClaim") (eq .persistentVolumeClaim.claimName $pvcName) }}
                {{- $usingPods = append $usingPods $pod }}
                {{- if not (hasKey $volStats "usedBytes") }}
                    {{- $volName := .name }}
                    {{- $nodeSummary := $pod.KubeGetNodeStatsSummary (get $pod.Spec "nodeName") }}
                    {{- $podStat := dict }}
                    {{- if $nodeSummary }}
                        {{- $podStat = $nodeSummary.pods | default list | getMatchingItemInMapList (dict "podRef.uid" $pod.Metadata.uid) }}
                    {{- end }}
                    {{- with $podStat.volume | default list | getMatchingItemInMapList (dict "name" $volName) }}
                        {{- $volStats = . }}
                    {{- end }}
                {{- end }}
            {{- end }}
        {{- end }}
    {{- end }}
    {{- if hasKey $volStats "usedBytes" }}
        {{- $used := $volStats.usedBytes | float64 }}
        {{- $cap := $volStats.capacityBytes | float64 }}
        {{- if $cap }}
            {{- $pct := percent $used $cap }}
            {{- printf ", usage: %s/%s[%s]" ($used | humanizeSI "B") ($cap | humanizeSI "B") ($pct | colorPercent "%.0f%%") }}
        {{- end }}
    {{- end }}
    {{- if and .Spec.volumeName ($.Config.GetBool "deep") }}
        {{- $pv := $.KubeGetFirst "" "PersistentVolume" .Spec.volumeName }}
        {{- $.Include "PersistentVolume" $pv | nindent 4 }}
    {{- end }}
    {{- /* Resize tracking: resizeStatus (pre-1.28) and allocatedResources/allocatedResourceStatuses (1.23+) */ -}}
    {{- $status := .Status | default dict }}
    {{- $allocStorage := index ($status.allocatedResources | default dict) "storage" }}
    {{- $allocStatusStorage := index ($status.allocatedResourceStatuses | default dict) "storage" }}
    {{- if or $status.resizeStatus $allocStorage $allocStatusStorage }}
        {{- "Resize" | bold | nindent 2 }}:
        {{- if $allocStorage }} storage {{ ($status.capacity | default dict).storage | cyan }} → {{ $allocStorage | cyan }}{{ end }}
        {{- with $status.resizeStatus }} ({{ . | colorKeyword }}){{ end }}
        {{- with $allocStatusStorage }} {{ . }}{{ end }}
    {{- end }}
    {{- if $usingPods }}
        {{- "Pods" | bold | nindent 2 }}:
        {{- range $usingPods }}
            {{- $.Include "pod_health_summary" . | nindent 4 }}
        {{- end }}
    {{- end }}
    {{- template "recent_updates" . }}
    {{- template "events" . }}
    {{- template "owners" . }}
{{- end -}}