{{- define "ExternalSecret" }}
    {{- /*gotype: github.com/bergerx/kubectl-status/pkg/plugin.RenderableObject*/ -}}
    {{- /* GVK: external-secrets.io/v1, Kind=ExternalSecret */ -}}
    {{- template "status_summary_line" . }}
    {{- template "kstatus_summary" . }}
    {{- template "finalizer_details_on_termination" . }}
    {{- template "observed_generation_summary" . }}
    {{- template "application_details" . }}
    {{- /* Store reference — deep renders the store inline */}}
    {{- with .Spec.secretStoreRef }}
        {{- $storeKind := .kind | default "SecretStore" }}
        {{- if $.Config.GetBool "deep" }}
            {{- $obj := $.KubeGetFirst $.Namespace $storeKind .name }}
            {{- if $obj.Object }}{{ $.IncludeRenderableObject $obj | nindent 2 }}{{ end }}
        {{- else }}
            {{- "Store" | bold | nindent 2 }}: {{ $.Include "resource_ref" (dict "kind" $storeKind "name" .name) }}
        {{- end }}
    {{- end }}
    {{- /* Target secret — deep renders the Secret inline */}}
    {{- $targetName := .Spec.target.name | default .Name }}
    {{- if $.Config.GetBool "deep" }}
        {{- $secretObj := $.KubeGetFirst $.Namespace "Secret" $targetName }}
        {{- if $secretObj.Object }}{{ $.IncludeRenderableObject $secretObj | nindent 2 }}{{ end }}
    {{- else }}
        {{- "Syncs to" | bold | nindent 2 }} {{ $.Include "resource_ref" (dict "kind" "Secret" "name" $targetName) }}
        {{- with .Spec.target.template }}{{- with .type }} · type {{ . | cyan }}{{ end }}{{ end }}
        {{- if .Spec.target.immutable }} · {{ "immutable" | cyan }}{{ end }}
        {{- if and .Spec.target.deletionPolicy (ne .Spec.target.deletionPolicy "Retain") }} · on-delete {{ .Spec.target.deletionPolicy | cyan }}{{ end }}
    {{- end }}
    {{- /* Key mappings — spec but critical for understanding what is synced */}}
    {{- $data := .Spec.data | default list }}
    {{- $dataFrom := .Spec.dataFrom | default list }}
    {{- if and (gt (len $data) 0) (le (len $data) 6) }}
        {{- range $data }}
            {{- $ref := .remoteRef }}
            {{- printf "%s" $ref.key | cyan | nindent 4 }}
            {{- with $ref.property }}{{ printf "[%s]" . | cyan }}{{ end }}
            {{- with $ref.version }}{{ printf "@%s" . | cyan }}{{ end }}
            {{- printf " → %s" .secretKey | cyan }}
        {{- end }}
    {{- else if gt (len $data) 6 }}
        {{- printf "%d remote keys" (len $data) | cyan | nindent 4 }}
    {{- end }}
    {{- range $dataFrom }}
        {{- with .extract }}
            {{- printf "extract %s" .key | cyan | nindent 4 }}
            {{- with .property }}{{ printf "[%s]" . | cyan }}{{ end }}
            {{- with .version }}{{ printf "@%s" . | cyan }}{{ end }}
        {{- end }}
        {{- with .find }}
            {{- "find" | cyan | nindent 4 }}
            {{- with .name }}{{ with .regexp }} name~{{ . | cyan }}{{ end }}{{ end }}
            {{- with .path }} path={{ . | cyan }}{{ end }}
        {{- end }}
    {{- end }}
    {{- /* Sync windows restrict when periodic refreshes may run */}}
    {{- with .Spec.syncWindows }}
        {{- printf "Sync windows (%s)" .kind | bold | nindent 2 }}:
        {{- range .windows }}
            {{- printf "%s for %s" .schedule .duration | cyan | nindent 4 }}
        {{- end }}
    {{- end }}
    {{- /* Refresh schedule and last sync */}}
    {{- $refreshInterval := .Spec.refreshInterval | default "1h0m0s" }}
    {{- with .Spec.refreshPolicy }}
        {{- if ne . "Periodic" }}
            {{- "Refresh policy" | bold | nindent 2 }}: {{ . | cyan }}
        {{- end }}
    {{- end }}
    {{- "Refreshes" | bold | nindent 2 }} every {{ $refreshInterval | cyan }}
    {{- with .Status.refreshTime }}, last synced {{ . | colorAgo }}{{ agoSuffix }}{{ end }}
    {{- template "conditions_summary" . }}
    {{- template "recent_updates" . }}
    {{- template "events" . }}
    {{- template "owners" . }}
{{- end }}
